# AI 全网搜索（二选一，推荐 Tavily）
# TAVILY_API_KEY=          # https://tavily.com 免费额度
# SERPER_API_KEY=          # https://serper.dev Google 搜索 API
# AI_SEARCH_TIMEOUT_MS=90000

# AI 对话提供商：deepseek | ark（不设则：有 DeepSeek 用 DeepSeek，否则火山方舟）
# CHAT_PROVIDER=ark

# DeepSeek（大陆可直接访问，推荐）
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 火山方舟（AI 对话 + 图片识别 + 图像工坊文生图 + 云端转写，共用 Key）
# ARK_API_KEY=your_ark_api_key
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL=doubao-1-5-pro-32k-250115
# ARK_VISION_MODEL=doubao-1-5-vision-pro-32k-250115
# ARK_IMAGE_MODEL=doubao-seedream-4-0-250828

# 一键做 App（复用 AI 对话 Key，无需额外配置）
# APP_BUILDER_TIMEOUT_MS=180000

# 影视搜索（免费申请 https://www.themoviedb.org/settings/api）
TMDB_API_KEY=

# faster-whisper（字幕工坊 · 本地语音转写，无需 API Key）
# 安装: python3 -m pip install --user faster-whisper
# WHISPER_MODEL=base
# WHISPER_LANGUAGE=zh

# 云端转写（Whisper 兼容 API；字幕工坊可选「云端转写」，需 ARK_API_KEY）
# TRANSCRIBE_MODEL=whisper-1
# TRANSCRIBE_BASE_URL=
# TRANSCRIBE_LANGUAGE=zh
# MAX_TRANSCRIBE_SEC=600

# 影视资源下载（公开检索聚合接口，可选覆盖）
# MEDIA_RESOURCE_API_BASE=http://1.h88818.net/v
# MEDIA_RESOURCE_TAB=movie_test

# 文档转换
# PDF ↔ Word：云端 ConvertAPI（免费注册 https://www.convertapi.com）
CONVERTAPI_SECRET=your_convertapi_secret
# DOC_CONVERT_TIMEOUT_MS=300000
# PDF 转图片、图片转 PDF 无需 API，在服务器本地处理

# 用户账号、记忆库与邮箱验证
# USER_SESSION_SECRET=optional_random_string
# APP_BASE_URL=http://127.0.0.1:3000
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your@email.com
# SMTP_PASS=your_smtp_password
# SMTP_FROM="春雨集" <noreply@example.com>
# 未配置 SMTP 时，验证链接会打印在服务器控制台（开发模式）

# 素材库（双击导航栏「菠」图标进入）
ASSETS_PASSWORD=your_secret_password

# 视频提取 · 抖音（二选一，解析失败时再配）
# 方式一：从浏览器读 Cookie（Safari 先登录 douyin.com，启动前退出浏览器）
# YTDLP_COOKIES_FROM_BROWSER=safari
# 方式二：导出 Netscape cookies.txt → 见 cookies/README.md
# YTDLP_COOKIES=./cookies/douyin.txt

# 视频提取 · X (Twitter)（多数视频需登录 Cookie）
# 一键配置: ./scripts/setup-x-cookies.sh [chrome|safari|...]
# TWITTER_COOKIES=./cookies/x.txt
# TWITTER_COOKIES_FROM_BROWSER=safari
# 也可与 YouTube/Instagram 共用 SOCIAL_COOKIES / SOCIAL_COOKIES_FROM_BROWSER（默认 safari）

# 视频提取 · 微信视频号
# ./scripts/setup-yuanbao-cookies.sh --install-cron
# YUANBAO_SPH_COOKIES=./cookies/yuanbao.txt
# YUANBAO_COOKIES_FROM_BROWSER=safari
# WEIXIN_CHANNELS_TEST_URL=https://channels.weixin.qq.com/web/pages/feed?...
# ASSETS_SESSION_SECRET=optional_random_string
# iPhone 快捷指令访问本机 API 时，建议监听局域网：HOST=0.0.0.0
