# AI 全网搜索（二选一，推荐 Tavily）
# TAVILY_API_KEY=          # https://tavily.com 免费额度
# SERPER_API_KEY=          # https://serper.dev Google 搜索 API
# AI_SEARCH_TIMEOUT_MS=90000

# AI 对话提供商：deepseek | openai | ark（不设则：有 DeepSeek 用 DeepSeek，否则 OpenAI）
# CHAT_PROVIDER=openai

# 方案 A：DeepSeek（大陆可直接访问，推荐）
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 方案 B：ChatGPT / OpenAI 兼容 API（大陆需代理或中转网关）
# 使用 ChatGPT 时请设置 CHAT_PROVIDER=openai，并注释或删除上面的 DEEPSEEK_API_KEY
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# 本机有 VPN/Clash 时（端口按你的客户端修改，常见 7890）：
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# 或使用国内可访问的 OpenAI 兼容中转，把 OPENAI_BASE_URL 改成对方提供的地址
# 图片识别（AI 对话上传图）：auto=优先 DeepSeek，不支持时回退 xAI | xai | deepseek
# IMAGE_VISION_PROVIDER=auto
# DEEPSEEK_VISION_MODEL=deepseek-v4-pro
# 兼容旧变量名（可选）
# ARK_API_KEY=
# ARK_BASE_URL=
# ARK_MODEL=

# 影视搜索（免费申请 https://www.themoviedb.org/settings/api）
TMDB_API_KEY=

# 图像工坊 · xAI 文生图（https://console.x.ai）
# XAI_API_KEY=
# XAI_BASE_URL=https://api.x.ai/v1
# XAI_IMAGE_MODEL=grok-imagine-image-quality
# 图片识别回退（DeepSeek 对话 API 暂不支持传图时必需其一）
# XAI_API_KEY=
# XAI_VISION_MODEL=grok-2-vision-1212

# faster-whisper（字幕工坊 · 本地语音转写，无需 API Key）
# 安装: python3 -m pip install --user faster-whisper
# WHISPER_MODEL=base
# WHISPER_LANGUAGE=zh

# 可选：云端转写（Whisper 兼容 API，本地不可用时回退）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# TRANSCRIBE_MODEL=whisper-1
# MAX_TRANSCRIBE_SEC=600

# 影视资源下载（公开检索聚合接口，可选覆盖）
# MEDIA_RESOURCE_API_BASE=http://1.h88818.net/v
# MEDIA_RESOURCE_TAB=movie_test

# 文档转换
# PDF ↔ Word：云端 ConvertAPI（免费注册 https://www.convertapi.com）
CONVERTAPI_SECRET=your_convertapi_secret
# DOC_CONVERT_TIMEOUT_MS=300000
# 国内访问 OpenAI / ConvertAPI 等可配置代理（与上方 AI 对话共用）：
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# PDF 转图片、图片转 PDF 无需 API，在服务器本地处理

# 素材库（双击导航栏「菠」图标进入）
ASSETS_PASSWORD=your_secret_password

# 视频提取 · 抖音（二选一，解析失败时再配）
# 方式一：从浏览器读 Cookie（Chrome 先登录 douyin.com，启动前退出浏览器）
# YTDLP_COOKIES_FROM_BROWSER=chrome
# 方式二：导出 Netscape cookies.txt → 见 cookies/README.md
# YTDLP_COOKIES=./cookies/douyin.txt

# 视频提取 · X (Twitter)（多数视频需登录 Cookie）
# 一键配置: ./scripts/setup-x-cookies.sh [chrome|safari|...]
# TWITTER_COOKIES=./cookies/x.txt
# TWITTER_COOKIES_FROM_BROWSER=chrome
# 也可与 YouTube/Instagram 共用 SOCIAL_COOKIES / SOCIAL_COOKIES_FROM_BROWSER
# ASSETS_SESSION_SECRET=optional_random_string
# iPhone 快捷指令访问本机 API 时，建议监听局域网：HOST=0.0.0.0
