# 闲聊对话 —— Grok CLI（官方安装，SuperGrok 账号登录，推荐）
# curl -fsSL https://x.ai/cli/install.sh | bash
# 或：./scripts/install-grok-cli.sh && grok login
GROK_USE_CLI=1

# 闲聊对话 —— Grok API（未启用 CLI 或 GROK_USE_CLI=0 时使用）
# 在 https://console.x.ai 创建 API Key
# XAI_API_KEY=xai-xxx
# XAI_BASE_URL=https://api.x.ai/v1
# XAI_MODEL=grok-4-1-fast
# 更强回复可改为：XAI_MODEL=grok-4.3

# 闲聊对话 —— 其他 OpenAI 兼容服务（未配置 XAI_API_KEY 时使用）
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# 影视搜索（免费申请 https://www.themoviedb.org/settings/api）
TMDB_API_KEY=

# AI 生视频（可选，https://replicate.com）
# REPLICATE_API_TOKEN=
# REPLICATE_VIDEO_VERSION=

# 素材库（双击导航栏「菠」图标进入）
ASSETS_PASSWORD=your_secret_password

# 视频提取 · YouTube / X / Instagram 等（登录后导出，可选更高画质）
# SOCIAL_COOKIES=./cookies/social.txt
# SOCIAL_COOKIES_FROM_BROWSER=chrome

# 视频提取 · B 站（登录 bilibili.com 后导出，可选 1080P/大会员）
# ./scripts/setup-bilibili-cookies.sh chrome
# BILIBILI_COOKIES=./cookies/bilibili.txt
# BILIBILI_COOKIES_FROM_BROWSER=chrome

# 视频提取 · 抖音（二选一，解析失败时再配）
# 方式一：从浏览器读 Cookie（Chrome 先登录 douyin.com，启动前退出浏览器）
# YTDLP_COOKIES_FROM_BROWSER=chrome
# 方式二：导出 Netscape cookies.txt → 见 cookies/README.md
# YTDLP_COOKIES=./cookies/douyin.txt
# ASSETS_SESSION_SECRET=optional_random_string
