# AI 对话 —— DeepSeek（https://platform.deepseek.com/api_keys）
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
# 图片识别（AI 对话上传图）：auto=优先 DeepSeek，不支持时回退 xAI | xai | deepseek
# IMAGE_VISION_PROVIDER=auto
# DEEPSEEK_VISION_MODEL=deepseek-v4-pro
# 兼容旧变量名（可选）
# ARK_API_KEY=
# ARK_BASE_URL=
# ARK_MODEL=

# 影视搜索（免费申请 https://www.themoviedb.org/settings/api）
TMDB_API_KEY=

# 图像工坊 · xAI 文生图（https://console.x.ai）
# XAI_API_KEY=
# XAI_BASE_URL=https://api.x.ai/v1
# XAI_IMAGE_MODEL=grok-imagine-image-quality
# 图片识别回退（DeepSeek 对话 API 暂不支持传图时必需其一）
# XAI_API_KEY=
# XAI_VISION_MODEL=grok-2-vision-1212

# faster-whisper（字幕工坊 · 本地语音转写，无需 API Key）
# 安装: python3 -m pip install --user faster-whisper
# WHISPER_MODEL=base
# WHISPER_LANGUAGE=auto

# 可选：云端转写（Whisper 兼容 API，本地不可用时回退）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# TRANSCRIBE_MODEL=whisper-1
# MAX_TRANSCRIBE_SEC=600

# 影视资源下载（公开检索聚合接口，可选覆盖）
# MEDIA_RESOURCE_API_BASE=http://1.h88818.net/v
# MEDIA_RESOURCE_TAB=movie_test

# 文档转换
# PDF ↔ Word：云端 ConvertAPI（免费注册 https://www.convertapi.com）
CONVERTAPI_SECRET=your_convertapi_secret
# DOC_CONVERT_TIMEOUT_MS=300000
# 国内网络不稳定时可配置代理：HTTPS_PROXY=http://127.0.0.1:7890
# PDF 转图片、图片转 PDF 无需 API，在服务器本地处理

# 素材库（双击导航栏「菠」图标进入）
ASSETS_PASSWORD=your_secret_password

# 视频提取 · 抖音（二选一，解析失败时再配）
# 方式一：从浏览器读 Cookie（Chrome 先登录 douyin.com，启动前退出浏览器）
# YTDLP_COOKIES_FROM_BROWSER=chrome
# 方式二：导出 Netscape cookies.txt → 见 cookies/README.md
# YTDLP_COOKIES=./cookies/douyin.txt
# ASSETS_SESSION_SECRET=optional_random_string
# iPhone 快捷指令访问本机 API 时，建议监听局域网：HOST=0.0.0.0
