{
  "name": "pineapple-toolbox",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 127.0.0.1 -p 3002",
    "dev:api": "API_ONLY=1 PORT=3001 node server/index.mjs",
    "dev:all": "bash scripts/dev-all.sh",
    "build": "next build",
    "start": "node server/index.mjs",
    "clean": "rm -rf .next out",
    "preview": "npm run clean && npm run build && npm run start",
    "lint": "next lint",
    "test:weixin-channels": "node scripts/test-weixin-channels.mjs",
    "test:video-platforms": "node scripts/test-video-platforms.mjs",
    "test:douyin-publish": "node scripts/test-douyin-publish.mjs"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@imgly/background-removal": "^1.5.7",
    "axios": "^1.7.9",
    "cheerio": "^1.0.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "libreoffice-convert": "^1.8.1",
    "multer": "^1.4.5-lts.1",
    "next": "^15.3.3",
    "nodemailer": "^8.0.10",
    "openai": "^4.77.0",
    "opencc-js": "^1.0.5",
    "pdf-lib": "^1.17.1",
    "pdf-to-img": "^6.1.0",
    "pdfjs-dist": "~5.6.205",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3"
  }
}
